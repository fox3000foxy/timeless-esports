{
  "name": "timeless-esports-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "create-cname": "echo timeless-esports.foxyagency.fr > dist/CNAME",
    "preview": "vite preview",
    "format": "bunx --bun @biomejs/biome format --write ./src",
    "check": "bunx --bun @biomejs/biome check ./src",
    "lint": "bunx --bun @biomejs/biome lint ./src",
    "deploy-page": "bun run build && bun run create-cname && cp dist/index.html dist/404.html && bunx gh-pages -d dist --nojekyll",
    "lint:write": "bunx --bun @biomejs/biome lint --write ./src"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "html2canvas": "^1.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/aos": "^3.0.7",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "rollup-plugin-purgecss": "^8.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.7"
  }
}
